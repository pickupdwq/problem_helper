---
import Layout from './Layout.astro';
import type { MarkdownLayoutProps } from 'astro';

interface Frontmatter {
	title: string;
	description?: string;
	lang?: string;
	pubDate?: string;
	author?: string;
	tags?: string[];
	draft?: boolean;
	cover?: ArticleImage;
	images?: ArticleImage[];
}

interface ArticleImage {
	src: string;
	alt: string;
	caption?: string;
	style?: string;
	source?: string;
}

type Props = MarkdownLayoutProps<Frontmatter>;
const { frontmatter, url } = Astro.props as Props;
const {
	title,
	description = '',
	lang = 'zh-CN',
	pubDate,
	author,
	tags = [],
	cover,
	images = [],
} = frontmatter;

const pubDateObj = pubDate ? new Date(pubDate) : null;
const publishedTime =
	pubDateObj && !Number.isNaN(pubDateObj.valueOf()) ? pubDateObj.toISOString() : undefined;
const formattedDate = pubDateObj
	? pubDateObj.toLocaleDateString('zh-CN', {
			year: 'numeric',
			month: 'long',
			day: 'numeric',
		})
	: undefined;
const articleUrl =
	Astro.site && url
		? new URL(url === '/' ? '/' : url.replace(/\/+$/, ''), Astro.site).toString()
		: undefined;
const structuredImages = [cover, ...images].filter((image): image is ArticleImage => Boolean(image));
const structuredData = Object.fromEntries(
	Object.entries({
		'@context': 'https://schema.org',
		'@type': 'Article',
		headline: title,
		description,
		inLanguage: lang,
		author: author ? { '@type': 'Person', name: author } : undefined,
		datePublished: publishedTime,
		mainEntityOfPage: articleUrl,
		image: structuredImages.length > 0 ? structuredImages.map((image) => image.src) : undefined,
		keywords: tags.length > 0 ? tags.join(', ') : undefined,
	}).filter(([, value]) => value !== undefined && value !== '')
);
const ogImagePath = cover?.src;
---

<Layout
	title={title}
	description={description}
	author={author}
	keywords={tags}
	lang={lang}
	ogImagePath={ogImagePath}
	ogType="article"
	publishedTime={publishedTime}
	structuredData={structuredData}
>
	<article class="article-page">
		<header class="article-header">
			<h1 class="article-title">{title}</h1>
			{(author || formattedDate) && (
				<div class="article-meta">
					{author && <span>{author}</span>}
					{author && formattedDate && <span class="meta-divider">/</span>}
					{formattedDate && <time datetime={publishedTime}>{formattedDate}</time>}
				</div>
			)}
			{tags.length > 0 && (
				<ul class="article-tags" aria-label="文章标签">
					{tags.map((tag) => <li>{tag}</li>)}
				</ul>
			)}
			{cover && (
				<figure class="article-cover">
					<img src={cover.src} alt={cover.alt} loading="eager" />
					{(cover.caption || cover.style || cover.source) && (
						<figcaption>
							{cover.caption && <span>{cover.caption}</span>}
							{cover.style && <span>风格：{cover.style}</span>}
							{cover.source && <span>来源：{cover.source}</span>}
						</figcaption>
					)}
				</figure>
			)}
		</header>
		<div class="article-content">
			<slot />
		</div>
		{images.length > 0 && (
			<section class="image-notes" aria-labelledby="image-notes-title">
				<h2 id="image-notes-title">图片信息</h2>
				<ul>
					{images.map((image) => (
						<li>
							<span>{image.caption || image.alt}</span>
							{image.style && <span>风格：{image.style}</span>}
							{image.source && <span>来源：{image.source}</span>}
						</li>
					))}
				</ul>
			</section>
		)}
	</article>
</Layout>

<style>
	.article-page {
		max-width: var(--content-width);
	}

	.article-header {
		margin-bottom: 3rem;
	}

	.article-title {
		margin: 0;
		font-size: clamp(2.2rem, 5vw, 3.4rem);
		line-height: 1.1;
		letter-spacing: 0;
	}

	.article-meta {
		margin-top: 1rem;
		display: flex;
		align-items: center;
		gap: 0.6rem;
		flex-wrap: wrap;
		font-size: 0.95rem;
		color: var(--text-secondary);
	}

	.meta-divider {
		color: var(--text-muted);
	}

	.article-tags {
		list-style: none;
		padding: 0;
		margin: 1rem 0 0;
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		color: var(--text-secondary);
		font-size: 0.92rem;
	}

	.article-cover {
		margin: 2rem 0 0;
	}

	.article-cover img {
		width: 100%;
		border: 1px solid rgba(15, 23, 42, 0.08);
		border-radius: 8px;
		background: rgba(255, 255, 255, 0.7);
		box-shadow: 0 16px 40px rgba(15, 23, 42, 0.08);
	}

	.article-cover figcaption,
	.article-content :global(figcaption) {
		margin-top: 0.7rem;
		display: grid;
		gap: 0.25rem;
		font-size: 0.88rem;
		line-height: 1.6;
		color: var(--text-secondary);
	}

	.article-content {
		font-size: 1.08rem;
		color: var(--text-primary);
	}

	.article-content :global(p),
	.article-content :global(ul),
	.article-content :global(ol),
	.article-content :global(blockquote),
	.article-content :global(figure),
	.article-content :global(pre) {
		margin: 1.35rem 0;
	}

	.article-content :global(figure) {
		margin: 2rem 0;
	}

	.article-content :global(h2) {
		margin: 3rem 0 1rem;
		font-size: 1.7rem;
		line-height: 1.25;
		letter-spacing: 0;
	}

	.article-content :global(h3) {
		margin: 2.25rem 0 0.85rem;
		font-size: 1.3rem;
		line-height: 1.3;
		letter-spacing: 0;
	}

	.article-content :global(a) {
		text-decoration: underline;
		text-decoration-color: rgba(31, 41, 55, 0.25);
		text-underline-offset: 0.18em;
	}

	.article-content :global(blockquote) {
		padding-left: 1rem;
		border-left: 2px solid rgba(31, 41, 55, 0.18);
		color: var(--text-secondary);
	}

	.article-content :global(img) {
		margin: 0 auto;
		border: 1px solid rgba(15, 23, 42, 0.08);
		border-radius: 8px;
		background: rgba(255, 255, 255, 0.7);
		box-shadow: 0 16px 40px rgba(15, 23, 42, 0.08);
	}

	.image-notes {
		margin-top: 3rem;
		padding-top: 1.5rem;
		border-top: 1px solid rgba(15, 23, 42, 0.08);
		color: var(--text-secondary);
	}

	.image-notes h2 {
		margin: 0;
		font-size: 1.05rem;
		letter-spacing: 0;
		color: var(--text-primary);
	}

	.image-notes ul {
		margin: 1rem 0 0;
		padding-left: 1.2rem;
	}

	.image-notes li {
		margin: 0.55rem 0;
	}

	.image-notes span + span::before {
		content: ' / ';
		color: var(--text-muted);
	}

	.article-content :global(pre) {
		padding: 1.1rem 1.25rem;
		border: 1px solid rgba(15, 23, 42, 0.08);
		border-radius: 6px;
		background: rgba(255, 255, 255, 0.72);
		overflow-x: auto;
	}

	.article-content :global(code) {
		font-family: 'SFMono-Regular', 'SF Mono', 'Menlo', 'Monaco', 'Consolas', monospace;
		font-size: 0.92em;
	}

	.article-content :global(:not(pre) > code) {
		padding: 0.15rem 0.35rem;
		border-radius: 4px;
		background: rgba(15, 23, 42, 0.05);
	}

	@media (max-width: 640px) {
		.article-header {
			margin-bottom: 2.25rem;
		}

		.article-content {
			font-size: 1rem;
		}
	}
</style>
