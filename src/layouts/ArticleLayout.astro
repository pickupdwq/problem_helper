---
import Layout from './Layout.astro';
import type { MarkdownLayoutProps } from 'astro';

interface Frontmatter {
	title: string;
	description?: string;
	lang?: string;
	pubDate?: string;
	author?: string;
	tags?: string[];
	draft?: boolean;
	cover?: ArticleImage;
	images?: ArticleImage[];
}

interface ArticleImage {
	src: string;
	alt: string;
	caption?: string;
	style?: string;
	source?: string;
}

type Props = MarkdownLayoutProps<Frontmatter>;
const { frontmatter, url } = Astro.props as Props;
const {
	title,
	description = '',
	lang = 'zh-CN',
	pubDate,
	author,
	tags = [],
	cover,
	images = [],
} = frontmatter;

const pubDateObj = pubDate ? new Date(pubDate) : null;
const publishedTime =
	pubDateObj && !Number.isNaN(pubDateObj.valueOf()) ? pubDateObj.toISOString() : undefined;
const formattedDate = pubDateObj
	? pubDateObj.toLocaleDateString('zh-CN', {
			year: 'numeric',
			month: 'long',
			day: 'numeric',
		})
	: undefined;
const articleUrl =
	Astro.site && url
		? new URL(url === '/' ? '/' : url.replace(/\/+$/, ''), Astro.site).toString()
		: undefined;
const structuredImages = [cover, ...images].filter((image): image is ArticleImage => Boolean(image));
const structuredData = Object.fromEntries(
	Object.entries({
		'@context': 'https://schema.org',
		'@type': 'Article',
		headline: title,
		description,
		inLanguage: lang,
		author: author ? { '@type': 'Person', name: author } : undefined,
		datePublished: publishedTime,
		mainEntityOfPage: articleUrl,
		image: structuredImages.length > 0 ? structuredImages.map((image) => image.src) : undefined,
		keywords: tags.length > 0 ? tags.join(', ') : undefined,
	}).filter(([, value]) => value !== undefined && value !== '')
);
const ogImagePath = cover?.src;
---

<Layout
	title={title}
	description={description}
	author={author}
	keywords={tags}
	lang={lang}
	ogImagePath={ogImagePath}
	ogType="article"
	publishedTime={publishedTime}
	structuredData={structuredData}
>
	<article class="article-page">
		<header class="article-header">
			<h1 class="article-title">{title}</h1>
			{(author || formattedDate) && (
				<div class="article-meta">
					{author && <span>{author}</span>}
					{author && formattedDate && <span class="meta-divider">/</span>}
					{formattedDate && <time datetime={publishedTime}>{formattedDate}</time>}
				</div>
			)}
			{tags.length > 0 && (
				<ul class="article-tags" aria-label="文章标签">
					{tags.map((tag) => <li>{tag}</li>)}
				</ul>
			)}
			{cover && (
				<figure class="article-cover">
					<img src={cover.src} alt={cover.alt} loading="eager" />
				</figure>
			)}
		</header>
		<div class="article-content">
			<slot />
		</div>
	</article>
</Layout>

<style>
	.article-page {
		max-width: var(--content-width);
		margin-inline: auto;
	}

	.article-header {
		margin-bottom: 3.4rem;
	}

	.article-title {
		margin: 0;
		max-width: 12em;
		font-family: var(--font-display);
		font-size: 3.05rem;
		line-height: 1.08;
		letter-spacing: 0;
		color: var(--text-strong);
	}

	.article-meta {
		margin-top: 1.15rem;
		display: flex;
		align-items: center;
		gap: 0.6rem;
		flex-wrap: wrap;
		font-size: 0.95rem;
		color: var(--text-secondary);
	}

	.meta-divider {
		color: var(--text-muted);
	}

	.article-tags {
		list-style: none;
		padding: 0;
		margin: 1.15rem 0 0;
		display: flex;
		flex-wrap: wrap;
		gap: 0.55rem;
		color: var(--text-muted);
		font-size: 0.92rem;
	}

	.article-tags li {
		padding: 0.2rem 0.55rem;
		border: 1px solid rgba(40, 78, 99, 0.14);
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.58);
	}

	.article-cover {
		margin: 2.2rem 0 0;
	}

	.article-cover img {
		width: 100%;
		aspect-ratio: 1200 / 630;
		object-fit: cover;
		border: 1px solid rgba(40, 78, 99, 0.12);
		border-radius: 10px;
		background: rgba(255, 255, 255, 0.78);
		box-shadow: var(--shadow-soft);
	}

	.article-content {
		font-family: var(--font-body);
		font-size: 1.08rem;
		line-height: 1.92;
		color: var(--text-primary);
		overflow-wrap: break-word;
	}

	.article-content :global(p),
	.article-content :global(ul),
	.article-content :global(ol),
	.article-content :global(blockquote),
	.article-content :global(figure),
	.article-content :global(pre) {
		margin: 1.35rem 0;
	}

	.article-content :global(p) {
		text-align: justify;
		text-underline-offset: 0.18em;
	}

	.article-content :global(> p:first-child) {
		margin-top: 0;
		font-size: 1.15rem;
		line-height: 1.9;
		color: var(--text-strong);
	}

	.article-content :global(figure) {
		margin: 2.25rem 0;
	}

	.article-content :global(h2) {
		position: relative;
		margin: 3.6rem 0 1rem;
		padding-top: 1rem;
		border-top: 1px solid rgba(40, 78, 99, 0.1);
		font-family: var(--font-display);
		font-size: 1.72rem;
		line-height: 1.25;
		letter-spacing: 0;
		color: var(--text-strong);
	}

	.article-content :global(h3) {
		margin: 2.25rem 0 0.85rem;
		font-size: 1.3rem;
		line-height: 1.3;
		letter-spacing: 0;
	}

	.article-content :global(a) {
		text-decoration: underline;
		text-decoration-color: rgba(40, 78, 99, 0.3);
		text-underline-offset: 0.18em;
	}

	.article-content :global(a:hover) {
		text-decoration-color: rgba(40, 78, 99, 0.7);
	}

	.article-content :global(img) {
		margin: 0 auto;
		aspect-ratio: 1200 / 630;
		object-fit: cover;
		border: 1px solid rgba(40, 78, 99, 0.12);
		border-radius: 10px;
		background: rgba(255, 255, 255, 0.78);
		box-shadow: var(--shadow-soft);
	}

	.article-content :global(figcaption) {
		display: none;
	}

	.article-content :global(pre) {
		padding: 1.15rem 1.25rem;
		border: 1px solid rgba(40, 78, 99, 0.14);
		border-radius: 10px;
		background: #182126;
		color: #f5f1e7;
		overflow-x: auto;
		box-shadow: 0 12px 34px rgba(24, 33, 38, 0.12);
	}

	.article-content :global(code) {
		font-family: 'SFMono-Regular', 'SF Mono', 'Menlo', 'Monaco', 'Consolas', monospace;
		font-size: 0.92em;
	}

	.article-content :global(:not(pre) > code) {
		padding: 0.12rem 0.36rem;
		border: 1px solid rgba(40, 78, 99, 0.12);
		border-radius: 6px;
		background: rgba(40, 78, 99, 0.07);
		color: var(--text-strong);
	}

	/* Heading hierarchy */
	.article-content :global(h4) {
		margin: 2rem 0 0.75rem;
		font-size: 1.1rem;
		line-height: 1.35;
		letter-spacing: 0;
		font-weight: 600;
	}

	.article-content :global(h5) {
		margin: 1.75rem 0 0.6rem;
		font-size: 1rem;
		line-height: 1.4;
		letter-spacing: 0;
		font-weight: 600;
	}

	.article-content :global(h6) {
		margin: 1.5rem 0 0.5rem;
		font-size: 0.95rem;
		line-height: 1.4;
		letter-spacing: 0;
		font-weight: 600;
		color: var(--text-secondary);
	}

	/* Table styling */
	.article-content :global(table) {
		width: 100%;
		border-collapse: separate;
		border-spacing: 0;
		margin: 1.7rem 0;
		font-size: 0.94rem;
		line-height: 1.62;
		border: 1px solid var(--panel-border);
		border-radius: 10px;
		overflow: hidden;
		background: rgba(255, 255, 255, 0.62);
		box-shadow: 0 10px 28px rgba(40, 78, 99, 0.05);
	}

	.article-content :global(thead) {
		background: transparent;
	}

	.article-content :global(th),
	.article-content :global(td) {
		padding: 0.72rem 0.92rem;
		text-align: left;
		border-bottom: 1px solid var(--panel-border);
		border-right: 1px solid var(--panel-border);
		vertical-align: top;
	}

	.article-content :global(th) {
		background: rgba(40, 78, 99, 0.08);
		font-weight: 650;
		color: var(--text-strong);
		border-bottom-width: 2px;
	}

	.article-content :global(td) {
		background: rgba(255, 253, 248, 0.46);
	}

	.article-content :global(tbody tr:nth-child(even) td) {
		background: rgba(40, 78, 99, 0.035);
	}

	.article-content :global(th:last-child),
	.article-content :global(td:last-child) {
		border-right: none;
	}

	.article-content :global(tbody tr:last-child td) {
		border-bottom: none;
	}

	.article-content :global(table::-webkit-scrollbar) {
		height: 6px;
	}

	.article-content :global(table::-webkit-scrollbar-track) {
		background: transparent;
	}

	.article-content :global(table::-webkit-scrollbar-thumb) {
		background: rgba(15, 23, 42, 0.15);
		border-radius: 3px;
	}

	.article-content :global(table::-webkit-scrollbar-thumb:hover) {
		background: rgba(15, 23, 42, 0.25);
	}

	/* Horizontal rule */
	.article-content :global(hr) {
		margin: 2.5rem 0;
		border: none;
		border-top: 1px solid rgba(40, 78, 99, 0.12);
	}

	/* List styling */
	.article-content :global(ul),
	.article-content :global(ol) {
		padding-left: 1.45rem;
	}

	.article-content :global(li) {
		margin: 0.48rem 0;
		padding-left: 0.15rem;
	}

	.article-content :global(li::marker) {
		color: var(--text-muted);
	}

	.article-content :global(ul > li) {
		list-style-type: disc;
	}

	.article-content :global(ul ul > li) {
		list-style-type: circle;
	}

	.article-content :global(ol > li) {
		list-style-type: decimal;
	}

	/* Enhanced blockquote */
	.article-content :global(blockquote) {
		position: relative;
		padding: 1.15rem 1.25rem;
		border-left: 3px solid rgba(40, 78, 99, 0.42);
		border-radius: 0 10px 10px 0;
		background: rgba(255, 255, 255, 0.58);
		color: var(--text-secondary);
		margin: 1.7rem 0;
		box-shadow: 0 8px 24px rgba(40, 78, 99, 0.05);
	}

	.article-content :global(blockquote p:first-child) {
		margin-top: 0;
	}

	.article-content :global(blockquote p:last-child) {
		margin-bottom: 0;
	}

	/* Code block scrollbar styling */
	.article-content :global(pre::-webkit-scrollbar) {
		height: 6px;
	}

	.article-content :global(pre::-webkit-scrollbar-track) {
		background: transparent;
	}

	.article-content :global(pre::-webkit-scrollbar-thumb) {
		background: rgba(15, 23, 42, 0.15);
		border-radius: 3px;
	}

	.article-content :global(pre::-webkit-scrollbar-thumb:hover) {
		background: rgba(15, 23, 42, 0.25);
	}

	/* Strong/bold text */
	.article-content :global(strong),
	.article-content :global(b) {
		font-weight: 600;
		color: var(--text-primary);
	}

	/* Definition list styling */
	.article-content :global(dl) {
		margin: 1.35rem 0;
	}

	.article-content :global(dt) {
		font-weight: 600;
		margin-top: 0.85rem;
		color: var(--text-primary);
	}

	.article-content :global(dd) {
		margin-left: 1.25rem;
		margin-top: 0.25rem;
		color: var(--text-secondary);
	}

	.article-content :global(.article-toc) {
		margin: 2rem 0 2.4rem;
		padding: 1rem 1.1rem;
		border: 1px solid rgba(40, 78, 99, 0.12);
		border-radius: 10px;
		background: rgba(255, 255, 255, 0.62);
		box-shadow: 0 10px 30px rgba(40, 78, 99, 0.05);
	}

	.article-content :global(.article-toc strong) {
		display: block;
		margin-bottom: 0.55rem;
		font-size: 0.92rem;
		color: var(--text-strong);
	}

	.article-content :global(.article-toc ul) {
		margin: 0;
		padding-left: 1.1rem;
	}

	.article-content :global(.article-toc li) {
		margin: 0.28rem 0;
	}

	.article-content :global(.article-toc a) {
		text-decoration: none;
		color: var(--text-secondary);
	}

	.article-content :global(.article-toc a:hover) {
		color: var(--text-strong);
	}

	@media (max-width: 640px) {
		.article-header {
			margin-bottom: 2.25rem;
		}

		.article-title {
			font-size: 2.35rem;
		}

		.article-content {
			font-size: 1rem;
			line-height: 1.86;
		}

		.article-content :global(> p:first-child) {
			font-size: 1.06rem;
		}

		.article-content :global(h2) {
			font-size: 1.48rem;
		}

		.article-content :global(pre) {
			margin-inline: -0.35rem;
			border-radius: 8px;
		}

		.article-content :global(table) {
			display: block;
			max-width: 100%;
			overflow-x: auto;
			-webkit-overflow-scrolling: touch;
			font-size: 0.9rem;
		}

		.article-content :global(th),
		.article-content :global(td) {
			min-width: 7.5rem;
			padding: 0.68rem 0.78rem;
		}

		.article-content :global(th:first-child),
		.article-content :global(td:first-child) {
			min-width: 6.5rem;
		}
	}
</style>
