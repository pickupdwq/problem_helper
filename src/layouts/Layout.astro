---
import Analytics from '@vercel/analytics/astro';
import Footer from '../components/Footer.astro';

interface Props {
	title?: string;
	description?: string;
	author?: string;
	keywords?: string[];
	lang?: string;
	ogImagePath?: string;
	ogType?: 'website' | 'article';
	publishedTime?: string;
	structuredData?: Record<string, unknown>;
}

const siteTitle = '派';
const siteDescription = '派的极简博客';
const defaultOgImagePath = '/og-cover.svg';

const {
	title = siteTitle,
	description = siteDescription,
	author,
	keywords = [],
	lang = 'zh-CN',
	ogImagePath = defaultOgImagePath,
	ogType = 'website',
	publishedTime,
	structuredData,
} = Astro.props;

const pageTitle = title === siteTitle ? title : `${title} | ${siteTitle}`;
const normalizedPathname =
	Astro.url.pathname === '/' ? '/' : Astro.url.pathname.replace(/\/+$/, '');
const canonicalUrl = Astro.site
	? new URL(normalizedPathname, Astro.site).toString()
	: undefined;
const ogImageUrl = Astro.site
	? new URL(ogImagePath, Astro.site).toString()
	: undefined;
const ogLocale = lang.toLowerCase().startsWith('zh') ? 'zh_CN' : 'en_US';
const structuredDataJson = structuredData ? JSON.stringify(structuredData) : null;
const analyticsEnabled = Astro.site ? Astro.site.hostname === 'yaiiii.com' : false;
---

<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="description" content={description} />
		<meta name="robots" content="index, follow" />
		{author && <meta name="author" content={author} />}
		{keywords.length > 0 && <meta name="keywords" content={keywords.join(', ')} />}
		<meta name="generator" content={Astro.generator} />
		{canonicalUrl && <link rel="canonical" href={canonicalUrl} />}

		<meta property="og:title" content={pageTitle} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content={ogType} />
		<meta property="og:locale" content={ogLocale} />
		<meta property="og:site_name" content={siteTitle} />
		{canonicalUrl && <meta property="og:url" content={canonicalUrl} />}
		{ogImageUrl && <meta property="og:image" content={ogImageUrl} />}
		{publishedTime && <meta property="article:published_time" content={publishedTime} />}
		{author && ogType === 'article' && <meta property="article:author" content={author} />}
		{keywords.map((keyword) => (
			<meta property="article:tag" content={keyword} />
		))}

		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={pageTitle} />
		<meta name="twitter:description" content={description} />
		{ogImageUrl && <meta name="twitter:image" content={ogImageUrl} />}

		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		{structuredDataJson && (
			<script type="application/ld+json" set:html={structuredDataJson}></script>
		)}
		<title>{pageTitle}</title>
	</head>
	<body>
		<div class="site-shell">
			<header class="site-header">
				<div class="site-header-inner">
					<nav class="site-nav" aria-label="主导航">
						<a href="/">首页</a>
					</nav>
				</div>
			</header>
			<main class="site-main">
				<slot />
			</main>
			<Footer />
		</div>
		{analyticsEnabled && <Analytics />}
	</body>
</html>

<style is:global>
	:root {
		color-scheme: light;
		--page-bg: #f7f3ea;
		--page-surface: #fffdf8;
		--panel-border: rgba(40, 78, 99, 0.12);
		--text-strong: #172126;
		--text-primary: #26343b;
		--text-secondary: #647178;
		--text-muted: #8d989d;
		--link-color: #284e63;
		--link-hover: #162f3f;
		--content-width: 47.5rem;
		--shell-width: min(100%, 58rem);
		--font-body: 'Avenir Next', 'Noto Sans SC', 'PingFang SC', 'Microsoft YaHei', sans-serif;
		--font-display: 'Songti SC', 'Noto Serif SC', 'Source Han Serif SC', 'STSong', serif;
		--shadow-soft: 0 18px 48px rgba(40, 78, 99, 0.09);
	}

	html {
		background: var(--page-bg);
		scroll-behavior: smooth;
	}

	html,
	body {
		margin: 0;
		width: 100%;
		min-height: 100%;
		font-family: var(--font-body);
		background: var(--page-bg);
		color: var(--text-primary);
		line-height: 1.75;
	}

	body {
		-webkit-font-smoothing: antialiased;
		text-rendering: optimizeLegibility;
		background:
			linear-gradient(180deg, rgba(255, 253, 248, 0.92) 0%, rgba(247, 243, 234, 0.96) 42%, #f7f3ea 100%),
			radial-gradient(circle at 18% 0%, rgba(105, 142, 157, 0.12), transparent 34%),
			radial-gradient(circle at 92% 16%, rgba(202, 168, 106, 0.11), transparent 30%);
	}

	* {
		box-sizing: border-box;
	}

	a {
		color: var(--link-color);
		text-decoration: none;
		text-underline-offset: 0.18em;
	}

	a:hover {
		color: var(--link-hover);
	}

	img {
		max-width: 100%;
		display: block;
	}

	.site-shell {
		min-height: 100vh;
		padding: 0 1.25rem;
		display: flex;
		flex-direction: column;
	}

	.site-header {
		padding: 1.4rem 0 2.7rem;
	}

	.site-header-inner {
		width: var(--shell-width);
		margin: 0 auto;
		display: flex;
		align-items: center;
		justify-content: flex-end;
		gap: 1rem;
	}

	.site-nav a {
		min-height: 2.5rem;
		display: inline-flex;
		align-items: center;
		padding: 0 0.75rem;
		border: 1px solid rgba(40, 78, 99, 0.12);
		border-radius: 999px;
		background: rgba(255, 253, 248, 0.7);
		font-size: 0.95rem;
		color: var(--text-secondary);
		transition:
			background-color 180ms ease,
			border-color 180ms ease,
			color 180ms ease;
	}

	.site-nav a:hover {
		border-color: rgba(40, 78, 99, 0.24);
		background: rgba(255, 253, 248, 0.95);
		color: var(--text-strong);
	}

	.site-nav {
		display: flex;
		align-items: center;
		gap: 1rem;
		color: var(--text-secondary);
	}

	.site-main {
		width: var(--shell-width);
		margin: 0 auto;
		flex: 1;
	}

	::selection {
		background: rgba(202, 168, 106, 0.28);
		color: var(--text-strong);
	}

	:focus-visible {
		outline: 2px solid rgba(40, 78, 99, 0.45);
		outline-offset: 3px;
	}

	@media (max-width: 640px) {
		.site-shell {
			padding: 0 1rem;
		}

		.site-header {
			padding: 1.25rem 0 2rem;
		}
	}
</style>
