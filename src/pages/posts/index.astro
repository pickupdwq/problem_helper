---
import Layout from '../../layouts/Layout.astro';
import { getAllPosts } from '../../utils/posts';

const posts = getAllPosts();
---

<Layout title="文章" description="最新文章列表">
	<section class="posts-page">
		<header class="posts-header">
			<h1>文章</h1>
			<p>持续更新的写作、笔记与想法。</p>
		</header>

		<div class="posts-divider" aria-hidden="true"></div>

		<div class="posts-feed">
			{posts.map((post) => (
				<article class="post-entry">
					<h2 class="post-entry-title">
						<a href={post.url}>{post.frontmatter.title}</a>
					</h2>
					{post.description && <p class="post-entry-summary">{post.description}</p>}
					<div class="post-entry-meta">
						<time datetime={post.pubDate.toISOString()}>{post.formattedDate}</time>
						<a class="post-entry-action" href={post.url}>阅读全文</a>
					</div>
				</article>
			))}
		</div>
	</section>
</Layout>

<style>
	.posts-page {
		max-width: var(--content-width);
		margin-inline: auto;
	}

	.posts-header {
		margin-bottom: 1.5rem;
	}

	.posts-header h1 {
		margin: 0;
		font-family: var(--font-display);
		font-size: 2.75rem;
		line-height: 1.15;
		letter-spacing: 0;
		color: var(--text-strong);
	}

	.posts-header p {
		margin: 0.85rem 0 0;
		font-size: 1.06rem;
		line-height: 1.8;
		color: var(--text-secondary);
	}

	.posts-divider {
		width: 100%;
		height: 1px;
		margin-bottom: 3rem;
		background: var(--panel-border);
	}

	.posts-feed {
		display: grid;
		gap: 1.25rem;
	}

	.post-entry {
		padding: 1.25rem 1.3rem;
		border: 1px solid rgba(40, 78, 99, 0.1);
		border-radius: 10px;
		background: rgba(255, 253, 248, 0.62);
		transition:
			border-color 180ms ease,
			background-color 180ms ease,
			transform 180ms ease;
	}

	.post-entry:hover {
		border-color: rgba(40, 78, 99, 0.22);
		background: rgba(255, 253, 248, 0.9);
		transform: translateY(-2px);
	}

	.post-entry-title {
		margin: 0;
		font-family: var(--font-display);
		font-size: 1.72rem;
		line-height: 1.25;
		letter-spacing: 0;
		color: var(--text-strong);
	}

	.post-entry-summary {
		margin: 0.9rem 0 0;
		font-size: 1rem;
		line-height: 1.78;
		color: var(--text-secondary);
	}

	.post-entry-meta {
		margin-top: 1rem;
		display: flex;
		align-items: center;
		gap: 1rem;
		flex-wrap: wrap;
		font-size: 0.92rem;
		color: var(--text-muted);
	}

	.post-entry-action {
		color: var(--text-primary);
	}

	.post-entry-action:hover,
	.post-entry-title a:hover {
		text-decoration: underline;
		text-decoration-color: rgba(31, 41, 55, 0.24);
		text-underline-offset: 0.18em;
	}

	@media (max-width: 640px) {
		.posts-header {
			margin-bottom: 1.25rem;
		}

		.posts-divider {
			margin-bottom: 2.5rem;
		}

		.posts-feed {
			gap: 1rem;
		}

		.posts-header h1 {
			font-size: 2.25rem;
		}

		.post-entry {
			padding: 1rem;
		}

		.post-entry-title {
			font-size: 1.42rem;
		}
	}
</style>
