---
import Layout from '../layouts/Layout.astro';
import { getAllPosts } from '../utils/posts';

const recentPosts = getAllPosts().slice(0, 3);
---

<Layout title="派" description="派的极简博客，记录写作、问题拆解与持续更新的思考。">
	<section class="home-page">
		<header class="home-hero">
			<p class="home-kicker">派</p>
			<h1>写作、笔记与问题拆解</h1>
			<p class="home-summary">
				这里收纳持续更新的文章、技术思考和长期有用的问题分析。
			</p>
		</header>

		<section class="home-section" aria-labelledby="recent-posts">
			<div class="section-head">
				<h2 id="recent-posts">最新文章</h2>
				<a href="/posts">查看全部</a>
			</div>
			<div class="home-feed">
				{recentPosts.map((post) => (
					<article class="home-entry">
						<h3 class="home-entry-title">
							<a href={post.url}>{post.frontmatter.title}</a>
						</h3>
						{post.description && <p class="home-entry-summary">{post.description}</p>}
						<time datetime={post.pubDate.toISOString()}>{post.formattedDate}</time>
					</article>
				))}
			</div>
		</section>
	</section>
</Layout>

<style>
	.home-page {
		max-width: var(--content-width);
		margin-inline: auto;
	}

	.home-hero {
		padding: 2.2rem 0 3.25rem;
	}

	.home-kicker {
		margin: 0;
		font-size: 0.92rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--text-muted);
	}

	.home-hero h1 {
		margin: 0.9rem 0 0;
		max-width: 10em;
		font-family: var(--font-display);
		font-size: 3.35rem;
		line-height: 1.08;
		letter-spacing: 0;
		color: var(--text-strong);
	}

	.home-summary {
		margin: 1.1rem 0 0;
		max-width: 32rem;
		font-size: 1.08rem;
		line-height: 1.85;
		color: var(--text-secondary);
	}

	.home-section {
		padding-top: 1.7rem;
		border-top: 1px solid var(--panel-border);
	}

	.section-head {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: 1rem;
	}

	.section-head h2 {
		margin: 0;
		font-family: var(--font-display);
		font-size: 1.45rem;
		color: var(--text-strong);
	}

	.section-head a {
		font-size: 0.95rem;
		color: var(--text-secondary);
	}

	.home-feed {
		display: grid;
		gap: 1.25rem;
		margin-top: 2rem;
	}

	.home-entry {
		padding: 1.15rem 1.25rem;
		border: 1px solid rgba(40, 78, 99, 0.1);
		border-radius: 10px;
		background: rgba(255, 253, 248, 0.62);
		transition:
			border-color 180ms ease,
			background-color 180ms ease,
			transform 180ms ease;
	}

	.home-entry:hover {
		border-color: rgba(40, 78, 99, 0.22);
		background: rgba(255, 253, 248, 0.9);
		transform: translateY(-2px);
	}

	.home-entry-title {
		margin: 0;
		font-family: var(--font-display);
		font-size: 1.38rem;
		line-height: 1.3;
		color: var(--text-strong);
	}

	.home-entry-summary {
		margin: 0.7rem 0 0;
		line-height: 1.75;
		color: var(--text-secondary);
	}

	.home-entry time {
		display: inline-block;
		margin-top: 0.85rem;
		font-size: 0.92rem;
		color: var(--text-muted);
	}

	@media (max-width: 640px) {
		.home-hero {
			padding: 1rem 0 2.5rem;
		}

		.home-hero h1 {
			font-size: 2.45rem;
		}

		.home-entry {
			padding: 1rem;
		}
	}
</style>
